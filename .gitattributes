# Auto detect text files and normalize line endings to LF
* text=auto

# Source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.astro text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.css text eol=lf

# Binary files
*.exe binary
*.bin binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
