---
import Layout from '../../layouts/Layout.astro';
import { downloadsData } from '../../lib/downloads';

let downloads = downloadsData;
const sortedDownloads = downloads.sort((a, b) => b.data.releaseDate.getTime() - a.data.releaseDate.getTime());

// Group downloads by vendor
const groupedByVendor = sortedDownloads.reduce((acc, download) => {
    const vendor = download.data.vendor || 'Other';
    if (!acc[vendor]) {
        acc[vendor] = [];
    }
    acc[vendor].push(download);
    return acc;
}, {} as Record<string, typeof downloads>);

// Sort vendors alphabetically
const sortedVendors = Object.keys(groupedByVendor).sort((a, b) => a.toLowerCase().localeCompare(b.toLowerCase()));
---

<Layout title="Downloads | AutoPacker - Software & Tools">
    <div class="mb-12 md:mb-24 text-center max-w-3xl mx-auto">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-black bg-clip-text text-transparent bg-gradient-to-b from-slate-800 to-slate-600 dark:from-slate-100 dark:to-slate-400 pb-4 transition-colors duration-300 hover:from-blue-600">
            Downloads & Resources
        </h1>
        <p class="text-base sm:text-lg text-slate-600 dark:text-slate-300 mt-4">
            Professional tools, templates, and documentation for enterprise software packaging and deployment. Download software organized by vendor.
        </p>
    </div>

    <!-- Table View - Organized by Vendor -->
    <div class="mb-12 space-y-8 md:space-y-12">
        {sortedVendors.map((vendor) => (
            <div>
                <div class="mb-4 md:mb-6">
                    <h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-slate-100 pb-3 border-b-2 border-blue-600/30 dark:border-blue-400/30">
                        {vendor}
                    </h2>
                    <p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 mt-2">
                        {groupedByVendor[vendor].length} product(s)
                    </p>
                </div>

                <!-- Desktop Table View -->
                <div class="hidden sm:block overflow-x-auto rounded-2xl border border-slate-200 dark:border-slate-800">
                    <table class="w-full text-sm md:text-base">
                        <thead>
                            <tr class="bg-slate-100/50 dark:bg-slate-900/50 border-b border-slate-200 dark:border-slate-800">
                                <th class="px-4 sm:px-6 py-3 md:py-4 text-left font-bold text-slate-900 dark:text-slate-100">Product</th>
                                <th class="px-4 sm:px-6 py-3 md:py-4 text-left font-bold text-slate-900 dark:text-slate-100">Version</th>
                                <th class="hidden sm:table-cell px-4 sm:px-6 py-3 md:py-4 text-left font-bold text-slate-900 dark:text-slate-100">Size</th>
                                <th class="hidden md:table-cell px-4 sm:px-6 py-3 md:py-4 text-left font-bold text-slate-900 dark:text-slate-100">Released</th>
                                <th class="px-4 sm:px-6 py-3 md:py-4 text-center font-bold text-slate-900 dark:text-slate-100">Download</th>
                            </tr>
                        </thead>
                        <tbody>
                            {groupedByVendor[vendor].map((download, idx) => (
                                <tr class={`border-b border-slate-200 dark:border-slate-800 transition-colors duration-200 hover:bg-blue-50 dark:hover:bg-blue-900/10 ${idx % 2 === 0 ? 'bg-white/50 dark:bg-slate-900/30' : 'bg-slate-50/30 dark:bg-slate-800/20'}`}>
                                    <td class="px-4 sm:px-6 py-3 md:py-4">
                                        <a href={`/downloads/${download.slug}`} class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold transition-colors">
                                            {download.data.title}
                                        </a>
                                        <p class="text-xs text-slate-600 dark:text-slate-400 mt-1 line-clamp-1">{download.data.description}</p>
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 md:py-4 text-xs md:text-sm font-mono text-slate-700 dark:text-slate-300 whitespace-nowrap">
                                        v{download.data.version}
                                    </td>
                                    <td class="hidden sm:table-cell px-4 sm:px-6 py-3 md:py-4 text-xs md:text-sm text-slate-700 dark:text-slate-300 whitespace-nowrap">
                                        {download.data.fileSize}
                                    </td>
                                    <td class="hidden md:table-cell px-4 sm:px-6 py-3 md:py-4 text-xs md:text-sm text-slate-700 dark:text-slate-300 whitespace-nowrap">
                                        {new Date(download.data.releaseDate).toLocaleDateString('en-US', { year: '2-digit', month: 'short', day: 'numeric' })}
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 md:py-4 text-center">
                                        <a href={download.data.downloadUrl} download class="inline-flex items-center justify-center gap-1 px-3 py-2 md:px-4 md:py-2 bg-blue-600 hover:bg-blue-700 dark:bg-blue-600 dark:hover:bg-blue-700 text-white rounded-lg font-semibold text-xs md:text-sm transition-colors duration-200 active:opacity-90 touch-target">
                                            <span>⬇</span>
                                            <span class="hidden sm:inline">Download</span>
                                        </a>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>

                <!-- Mobile Card View -->
                <div class="sm:hidden grid gap-4 grid-cols-1">
                    {groupedByVendor[vendor].map((download) => (
                        <div class="p-4 rounded-xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200">
                            <div class="space-y-3">
                                <div>
                                    <a href={`/downloads/${download.slug}`} class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold text-sm transition-colors block truncate">
                                        {download.data.title}
                                    </a>
                                    <p class="text-xs text-slate-600 dark:text-slate-400 mt-1 line-clamp-2">{download.data.description}</p>
                                </div>
                                
                                <div class="grid grid-cols-3 gap-2 text-xs text-slate-700 dark:text-slate-300">
                                    <div>
                                        <span class="block font-semibold text-slate-900 dark:text-slate-100">v{download.data.version}</span>
                                        <span class="text-slate-500">Version</span>
                                    </div>
                                    <div>
                                        <span class="block font-semibold text-slate-900 dark:text-slate-100">{download.data.fileSize}</span>
                                        <span class="text-slate-500">Size</span>
                                    </div>
                                    <div>
                                        <span class="block font-semibold text-slate-900 dark:text-slate-100">{new Date(download.data.releaseDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                                        <span class="text-slate-500">Released</span>
                                    </div>
                                </div>

                                <div class="flex gap-2 pt-2">
                                    <a href={`/downloads/${download.slug}`} class="flex-1 px-3 py-2 rounded-lg border border-blue-600 dark:border-blue-500 text-blue-600 dark:text-blue-400 font-semibold text-sm transition-colors hover:bg-blue-50 dark:hover:bg-blue-900/20 text-center active:opacity-75">
                                        View Details
                                    </a>
                                    <a href={download.data.downloadUrl} download class="flex-1 px-3 py-2 bg-blue-600 hover:bg-blue-700 dark:bg-blue-600 dark:hover:bg-blue-700 text-white rounded-lg font-semibold text-sm transition-colors duration-200 active:opacity-90 text-center">
                                        ⬇ Download
                                    </a>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        ))}
    </div>

    {sortedDownloads.length === 0 && (
        <div class="text-center py-12 md:py-16">
            <p class="text-slate-600 dark:text-slate-400 text-base md:text-lg">No downloads available yet. Check back soon!</p>
        </div>
    )}

    <!-- Additional Info Section -->
    <div class="mt-16 md:mt-24 pt-8 md:pt-12 border-t border-slate-200 dark:border-slate-800">
        <h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-slate-100 mb-6 md:mb-8">How to Use These Downloads</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-8">
            <div class="p-4 md:p-6 rounded-xl md:rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200">
                <div class="text-2xl md:text-3xl mb-3">1️⃣</div>
                <h3 class="text-base md:text-lg font-bold text-slate-900 dark:text-slate-100 mb-2">Find Your Software</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400">Browse the list above organized by vendor. Click on any product name to see full details and system requirements.</p>
            </div>
            <div class="p-4 md:p-6 rounded-xl md:rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200">
                <div class="text-2xl md:text-3xl mb-3">2️⃣</div>
                <h3 class="text-base md:text-lg font-bold text-slate-900 dark:text-slate-100 mb-2">Click to Download</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400">Click the "Download" button to immediately get the latest version. Your browser will start the download automatically.</p>
            </div>
            <div class="p-4 md:p-6 rounded-xl md:rounded-2xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200">
                <div class="text-2xl md:text-3xl mb-3">3️⃣</div>
                <h3 class="text-base md:text-lg font-bold text-slate-900 dark:text-slate-100 mb-2">Install Safely</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400">Check system requirements and read installation instructions on the detailed product page before running the installer.</p>
            </div>
        </div>
    </div>
</Layout>

