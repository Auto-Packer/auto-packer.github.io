---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | AutoPacker">
    <div class="mb-16 md:mb-24 text-center max-w-2xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-black bg-clip-text text-transparent bg-gradient-to-b from-slate-800 to-slate-600 dark:from-slate-100 dark:to-slate-400 pb-4">
            Get in Touch
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-300 mt-2">
            Have questions about application packaging or need a consultation? Reach out to us directly.
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Contact Information -->
        <div class="space-y-6">
            <!-- Email Contact -->
            <div class="bg-white/50 dark:bg-slate-900/50 rounded-2xl p-8 border border-slate-200 dark:border-slate-800">
                <div class="flex items-start gap-4">
                    <div class="flex-shrink-0">
                        <svg class="w-6 h-6 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-1">Email</h3>
                        <a href="mailto:Rajeev.Autopacker@outlook.com" class="text-cyan-600 dark:text-cyan-400 hover:underline break-all">
                            Rajeev.Autopacker@outlook.com
                        </a>
                        <p class="text-sm text-slate-600 dark:text-slate-400 mt-2">We'll respond within 24 hours</p>
                    </div>
                </div>
            </div>

            <!-- Phone Contact -->
            <div class="bg-white/50 dark:bg-slate-900/50 rounded-2xl p-8 border border-slate-200 dark:border-slate-800">
                <div class="flex items-start gap-4">
                    <div class="flex-shrink-0">
                        <svg class="w-6 h-6 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-1">Phone</h3>
                        <a href="tel:+917303383696" class="text-cyan-600 dark:text-cyan-400 hover:underline">
                            +91 7303 383 696
                        </a>
                        <p class="text-sm text-slate-600 dark:text-slate-400 mt-2">Available for consultations</p>
                    </div>
                </div>
            </div>

            <!-- LinkedIn & Social -->
            <div class="bg-gradient-to-br from-blue-50 to-cyan-50 dark:from-blue-900/20 dark:to-cyan-900/20 rounded-2xl p-8 border border-blue-200 dark:border-blue-800">
                <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-4">Connect on LinkedIn</h3>
                <a 
                    href="https://www.linkedin.com/in/rkush07" 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded-lg transition-all duration-200 transform hover:scale-105"
                >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.731-2.004 1.437-.103.249-.129.597-.129.946v5.422h-3.554s.05-8.8 0-9.714h3.554v1.375c.428-.659 1.191-1.597 2.896-1.597 2.115 0 3.701 1.383 3.701 4.361v5.575zM5.337 8.855c-1.144 0-1.915-.758-1.915-1.704 0-.954.768-1.704 1.959-1.704 1.188 0 1.914.75 1.939 1.704 0 .946-.751 1.704-1.983 1.704zm1.946 11.597H3.392V9.738h3.891v10.714zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
                    </svg>
                    LinkedIn Profile
                </a>
                <p class="text-sm text-slate-600 dark:text-slate-400 mt-4">Follow for updates and insights on application packaging</p>
            </div>
        </div>
    </div>

    <div class="mt-16 text-center">
        <p class="text-sm text-slate-600 dark:text-slate-400">Enterprise packaging solutions. Engineered to scale.</p>
    </div>
</Layout>
