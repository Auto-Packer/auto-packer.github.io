---
import ThemeToggle from '../components/ThemeToggle.astro';
export interface Props {
	title: string;
}

const { title } = Astro.props;

const isCurrentPage = (url: string) => {
    const currentPath = Astro.url.pathname;
    if (url === '/') return currentPath === '/';
    return currentPath.startsWith(url);
}
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="description" content="High-end, enterprise B2B IT consulting for application packaging and deployment." />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Roboto+Mono&display=swap" rel="stylesheet">
    <script is:inline>
        // This script is inlined to avoid FOUC (Flash of Unstyled Content)
        // It checks local storage and system settings to apply the 'dark' class before the page loads.
        if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
        
        // Mobile menu toggle
        window.toggleMobileMenu = function() {
            const menu = document.getElementById('mobile-menu');
            menu.classList.toggle('hidden');
        };
    </script>
</head>
<body class="bg-white dark:bg-[#0b1120] text-slate-800 dark:text-slate-200 antialiased">

    <div class="absolute inset-0 -z-10 h-full w-full bg-white dark:bg-[#0b1120] bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#8080800a_1px,transparent_1px),linear-gradient(to_bottom,#8080800a_1px,transparent_1px)] bg-[size:14px_24px]"></div>

    <!-- Background Logo -->
    <div class="fixed inset-0 -z-20 overflow-hidden pointer-events-none">
        <img src="/AutoPacker_logo.jpeg" alt="" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 opacity-[0.15] dark:opacity-[0.08] blur-sm" />
    </div>

    <header class="sticky top-0 z-50 backdrop-blur-md bg-white/80 dark:bg-[#0b1120]/80 transition-colors duration-300">
        <div class="container mx-auto px-4 sm:px-6 md:px-8 py-4 md:py-6">
            <div class="flex justify-between items-center">
                <a href="/" class="flex items-center gap-2 group hover:opacity-80 transition-opacity duration-200 flex-shrink-0">
                    <img src="/AutoPacker_logo.jpeg" alt="AutoPacker Logo" class="h-8 sm:h-10 w-auto" />
                    <span class="hidden sm:inline text-lg font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-cyan-500 dark:from-blue-500 dark:to-cyan-400">AutoPacker.dev</span>
                </a>

                <!-- Desktop Navigation -->
                <nav class="hidden md:flex items-center space-x-6 text-slate-600 dark:text-slate-300">
                    <a href="/" class={`text-sm lg:text-base transition-colors duration-200 py-2 ${isCurrentPage('/') ? 'text-cyan-600 dark:text-cyan-400 font-semibold' : 'hover:text-cyan-600 dark:hover:text-cyan-400'}`}>Home</a>
                    <a href="/services" class={`text-sm lg:text-base transition-colors duration-200 py-2 ${isCurrentPage('/services') ? 'text-cyan-600 dark:text-cyan-400 font-semibold' : 'hover:text-cyan-600 dark:hover:text-cyan-400'}`}>Services</a>
                    <a href="/downloads" class={`text-sm lg:text-base transition-colors duration-200 py-2 ${isCurrentPage('/downloads') ? 'text-cyan-600 dark:text-cyan-400 font-semibold' : 'hover:text-cyan-600 dark:hover:text-cyan-400'}`}>Downloads</a>
                    <a href="/blog" class={`text-sm lg:text-base transition-colors duration-200 py-2 ${isCurrentPage('/blog') ? 'text-cyan-600 dark:text-cyan-400 font-semibold' : 'hover:text-cyan-600 dark:hover:text-cyan-400'}`}>Blog</a>
                    <ThemeToggle />
                </nav>

                <!-- Mobile Menu Button & Theme Toggle -->
                <div class="md:hidden flex items-center gap-2">
                    <ThemeToggle />
                    <button 
                        onclick="toggleMobileMenu()"
                        class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors duration-200"
                        aria-label="Toggle menu"
                    >
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Mobile Navigation Menu -->
            <nav id="mobile-menu" class="hidden md:hidden mt-4 pb-4 space-y-2 border-t border-slate-200 dark:border-slate-800 pt-4">
                <a href="/" class={`block px-4 py-3 rounded-lg transition-colors duration-200 ${isCurrentPage('/') ? 'bg-blue-50 dark:bg-blue-900/20 text-cyan-600 dark:text-cyan-400 font-semibold' : 'hover:bg-slate-100 dark:hover:bg-slate-800'}`}>Home</a>
                <a href="/services" class={`block px-4 py-3 rounded-lg transition-colors duration-200 ${isCurrentPage('/services') ? 'bg-blue-50 dark:bg-blue-900/20 text-cyan-600 dark:text-cyan-400 font-semibold' : 'hover:bg-slate-100 dark:hover:bg-slate-800'}`}>Services</a>
                <a href="/downloads" class={`block px-4 py-3 rounded-lg transition-colors duration-200 ${isCurrentPage('/downloads') ? 'bg-blue-50 dark:bg-blue-900/20 text-cyan-600 dark:text-cyan-400 font-semibold' : 'hover:bg-slate-100 dark:hover:bg-slate-800'}`}>Downloads</a>
                <a href="/blog" class={`block px-4 py-3 rounded-lg transition-colors duration-200 ${isCurrentPage('/blog') ? 'bg-blue-50 dark:bg-blue-900/20 text-cyan-600 dark:text-cyan-400 font-semibold' : 'hover:bg-slate-100 dark:hover:bg-slate-800'}`}>Blog</a>
            </nav>
        </div>
    </header>

    <main class="container mx-auto px-4 sm:px-6 md:px-8 py-8 sm:py-12 md:py-16">
        <slot />
    </main>

</body>
</html>
